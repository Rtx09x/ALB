# Agent Load Balancer uses ALB_* env vars. Legacy CODEX_LB_* names remain supported for migration.

# Database
ALB_DATABASE_URL=sqlite+aiosqlite:///~/.agent-load-balancer/store.db
# Optional PostgreSQL example (SQLite stays default if not set):
# ALB_DATABASE_URL=postgresql+asyncpg://alb:alb@127.0.0.1:5432/alb
ALB_DATABASE_MIGRATE_ON_STARTUP=true
ALB_DATABASE_SQLITE_PRE_MIGRATE_BACKUP_ENABLED=true
ALB_DATABASE_SQLITE_PRE_MIGRATE_BACKUP_MAX_FILES=5

# Upstream ChatGPT base URL (no /codex suffix)
ALB_UPSTREAM_BASE_URL=https://chatgpt.com/backend-api

# Timeouts (seconds)
ALB_UPSTREAM_CONNECT_TIMEOUT_SECONDS=30
ALB_PROXY_REQUEST_BUDGET_SECONDS=600
ALB_HTTP_RESPONSES_SESSION_BRIDGE_REQUEST_BUDGET_SECONDS=7200
ALB_STREAM_IDLE_TIMEOUT_SECONDS=300
# Upstream websocket handshakes auto-use proxy env vars when available.
# wss_proxy=
# ws_proxy=
# https_proxy=
# http_proxy=
# all_proxy=

# Set this explicitly to false only if websocket handshakes must bypass env proxies.
# ALB_UPSTREAM_WEBSOCKET_TRUST_ENV=false

# Warmup
ALB_WARMUP_MODEL=gpt-5.4-mini

# OAuth / token refresh
ALB_AUTH_BASE_URL=https://auth.openai.com
ALB_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
ALB_OAUTH_SCOPE="openid profile email"
ALB_OAUTH_TIMEOUT_SECONDS=30
ALB_OAUTH_REDIRECT_URI=http://localhost:1455/auth/callback
ALB_OAUTH_CALLBACK_HOST=127.0.0.1
# Do not change the port. OpenAI dislikes changes.
ALB_OAUTH_CALLBACK_PORT=1455
ALB_TOKEN_REFRESH_TIMEOUT_SECONDS=30
ALB_TOKEN_REFRESH_INTERVAL_DAYS=8

# Encryption key file (optional override; recommended for Docker volumes)
# ALB_ENCRYPTION_KEY_FILE=/var/lib/agent-load-balancer/encryption.key

# Upstream usage fetch
ALB_USAGE_FETCH_TIMEOUT_SECONDS=10
ALB_USAGE_FETCH_MAX_RETRIES=2
ALB_USAGE_REFRESH_ENABLED=true
ALB_USAGE_REFRESH_INTERVAL_SECONDS=60
ALB_STICKY_SESSION_CLEANUP_ENABLED=true
ALB_STICKY_SESSION_CLEANUP_INTERVAL_SECONDS=300

# Firewall
# Trust X-Forwarded-For for firewall client IP detection (enable only behind trusted reverse proxy)
ALB_FIREWALL_TRUST_PROXY_HEADERS=false
# Comma-separated CIDR list for trusted proxy sources
ALB_FIREWALL_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# Dashboard authentication mode:
# - standard: built-in password + optional TOTP (default)
# - trusted_header: trust a reverse proxy auth header from trusted proxy CIDRs; password/TOTP stay available as fallback and are still managed via fallback password sessions
# - disabled: bypass dashboard auth entirely (only use behind network restrictions or external auth); built-in password/TOTP management is off
ALB_DASHBOARD_AUTH_MODE=standard
# Header to trust in trusted_header mode (Authelia commonly forwards Remote-User)
ALB_DASHBOARD_AUTH_PROXY_HEADER=Remote-User
# Example trusted_header setup:
# ALB_DASHBOARD_AUTH_MODE=trusted_header
# ALB_FIREWALL_TRUST_PROXY_HEADERS=true
# ALB_FIREWALL_TRUSTED_PROXY_CIDRS=172.18.0.0/16
# ALB_DASHBOARD_AUTH_PROXY_HEADER=Remote-User
# Example hard bypass / Docker override:
# ALB_DASHBOARD_AUTH_MODE=disabled

# Production / Multi-Replica Settings
# Prometheus metrics (opt-in)
ALB_METRICS_ENABLED=false
ALB_METRICS_PORT=9090

# Logging format
ALB_LOG_FORMAT=text

# Full upstream conversation archive (opt-in; stores request/response bodies/events as gzip JSONL)
ALB_CONVERSATION_ARCHIVE_ENABLED=false
# ALB_CONVERSATION_ARCHIVE_DIR=~/.agent-load-balancer/conversation-archive
# ALB_CONVERSATION_ARCHIVE_QUEUE_MAX_BYTES=8388608

# Leader election (opt-in)
ALB_LEADER_ELECTION_ENABLED=false
ALB_LEADER_ELECTION_TTL_SECONDS=30

# Circuit breaker (opt-in)
ALB_CIRCUIT_BREAKER_ENABLED=false
ALB_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
ALB_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=60

# Backpressure (0 = unlimited)
ALB_BACKPRESSURE_MAX_CONCURRENT_REQUESTS=0

# OpenTelemetry (opt-in)
ALB_OTEL_ENABLED=false
ALB_OTEL_EXPORTER_ENDPOINT=

# Shutdown drain timeout
ALB_SHUTDOWN_DRAIN_TIMEOUT_SECONDS=30

# HTTP connector limits
ALB_HTTP_CONNECTOR_LIMIT=100
ALB_HTTP_CONNECTOR_LIMIT_PER_HOST=50

# Dashboard password/TOTP fallback is configured in the settings UI when dashboard auth mode allows it
